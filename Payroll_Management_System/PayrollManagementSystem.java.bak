import java.util.*;
class Member 
{
    public static final String RESET = "\u001B[0m";
    public static final String RED_BOLD = "\033[1;31m";   // RED
    public static final String GREEN_BOLD = "\033[1;32m"; // GREEN
    public static final String YELLOW_BOLD = "\033[1;33m";  // YELLOW
    public static final String BLUE_BOLD = "\033[1;34m";   // BLUE
    public static final String PURPLE_BOLD = "\033[1;35m"; // PURPLE
    public static final String CYAN_BOLD = "\033[1;36m";   // CYAN
    public static final String WHITE_BOLD = "\033[1;37m";  // WHITE
    int employeeId;
    String name;
    Member(int employeeId, String name) 	// Constructor to initialize Member Class
    {
        this.employeeId = employeeId;
        this.name = name;
    }
    void displayDetails() 				// Method to display employee details
    {
        System.out.println(CYAN_BOLD + "=========================================" + RESET);
        System.out.println(YELLOW_BOLD + "Employee ID      : " + RESET + employeeId);
        System.out.println(YELLOW_BOLD + "Name             : " + RESET + name);
        System.out.println(CYAN_BOLD + "=========================================" + RESET);
    }
}
class Employee extends Member 
{
    double basicSalary;
    int paidLeaves;
    double bonus;
    int overtimeHours;
    String phoneNumber;
    int noticePeriod;  

    Employee(int employeeId, String name, double basicSalary, int paidLeaves, double bonus, int overtimeHours, String phoneNumber, int noticePeriod) // Constructor to initialize Employee Class 
	{
        super(employeeId, name);
        this.basicSalary = basicSalary;
        this.paidLeaves = paidLeaves;
        this.bonus = bonus;
        this.overtimeHours = overtimeHours;
        this.phoneNumber = phoneNumber;
        this.noticePeriod = noticePeriod;
    }

    double calculateGrossSalary() 
	{
        double hra = basicSalary * 0.20; 			//House Rent Allowance (HRA) = 20% of basicSalary
        double da = basicSalary * 0.10;				//Dearness Allowance (DA) = 10% of basicSalary
        double overtimePay = overtimeHours * 1100;	// overtimePay = 1100* overtimeHours
        double leaveAllowance = paidLeaves * 1000;	//leaveAllowance = 1000* paidLeaves
        double pf = basicSalary * 0.12; 			//12% of basicSalary
        double professionalTax = basicSalary * 0.01;//1% of basicSalary
        double grossSalary = basicSalary + hra + da + overtimePay + leaveAllowance + bonus - pf - professionalTax;//Salary after deductions and allowance
        System.out.println(YELLOW_BOLD + "Provident Fund (12%): Rs." + RESET + pf);
        System.out.println(YELLOW_BOLD + "Professional Tax (1%): Rs." + RESET + professionalTax);
        System.out.println(GREEN_BOLD + "Gross Salary after Deductions: Rs." + RESET + grossSalary);
        return grossSalary;
    }

    void displayDetails() {
        super.displayDetails();
        System.out.println(YELLOW_BOLD + "Basic Salary     : Rs." + RESET + basicSalary);
        System.out.println(YELLOW_BOLD + "Paid Leaves      : " + RESET + paidLeaves);
        System.out.println(YELLOW_BOLD + "Bonus            : Rs." + RESET + bonus);
        System.out.println(YELLOW_BOLD + "Overtime Hours   : " + RESET + overtimeHours);
        System.out.println(YELLOW_BOLD + "Phone Number     : " + RESET + phoneNumber);
        System.out.println(YELLOW_BOLD + "Notice Period    : " + RESET + noticePeriod + " days"); // Display notice period
        System.out.println(GREEN_BOLD + "Gross Salary     : Rs." + RESET + calculateGrossSalary());
        System.out.println(CYAN_BOLD + "=========================================" + RESET);
    }
}

class PayrollManagementSystem 
{
    static final int max_employees = 100;
    Employee[] employees = new Employee[max_employees];
    int employeeCount = 0;
    int employeeIdCounter = 1;
    Scanner Sc = new Scanner(System.in);
    public static final String RESET = "\u001B[0m";
    public static final String RED_BOLD = "\033[1;31m";   // RED
    public static final String GREEN_BOLD = "\033[1;32m"; // GREEN
    public static final String YELLOW_BOLD = "\033[1;33m";  // YELLOW
    public static final String BLUE_BOLD = "\033[1;34m";   // BLUE
    public static final String PURPLE_BOLD = "\033[1;35m"; // PURPLE
    public static final String CYAN_BOLD = "\033[1;36m";   // CYAN
    public static final String WHITE_BOLD = "\033[1;37m";  // WHITE
    public static void main(String[] args) 
    {
        System.out.println(CYAN_BOLD + "\n=== Welcome to the Payroll Management System ===" + RESET); 
        PayrollManagementSystem payroll = new PayrollManagementSystem();
        payroll.run();
        System.out.println(GREEN_BOLD + "\nThank you for using the Payroll Management System!" + RESET); 
    }
    void run() 								 // Main loop for user interactions
    {
        while (true) 
        {
            displayMenu();
            int choice = getValidChoice();
            switch (choice) 
            {
                case 1: 
				{
                    addEmployee(); //add Employee
                    break;
				}
                case 2: 
				{
                    viewAllEmployees(); // Viewing all employees
                    break;
				}
                case 3: 
				{
					searchEmployeeById(); // Search by ID
                    break;
				}
                case 4:
				{				
                    editEmployee("Name"); // Change name
                    break;
				}
                case 5: 
                {
					editEmployee("Salary"); // Change salary
                    break;
				}
                case 6:
				{				
                    deleteEmployee(); // Delete employee
                    break;
				}
                case 7:
				{				
                    sortEmployeesById(); // sort by ID
                    break;
				}
                case 8:
				{				
                    calculateAverageSalary(); // calculate the avg. salary
                    break;
				}
                case 9:
				{				
                    System.out.println(RED_BOLD + "\nExiting Payroll Management System. Goodbye!" + RESET); //exit
                    return;
				}
                default:
				{				
                    System.out.println(RED_BOLD + "Invalid choice. Please try again." + RESET);
					break;
				}
            }
        }
    }
    void displayMenu() 										//Method to display menu
    {
        System.out.println(CYAN_BOLD + "\n=== Payroll Management System ===" + RESET);
        System.out.println(BLUE_BOLD + "1. Add Employee" + RESET);
        System.out.println(BLUE_BOLD + "2. View All Employees" + RESET);
        System.out.println(BLUE_BOLD + "3. Search Employee by ID" + RESET);
        System.out.println(BLUE_BOLD + "4. Edit Employee Name" + RESET);
        System.out.println(BLUE_BOLD + "5. Edit Employee Salary" + RESET);
        System.out.println(BLUE_BOLD + "6. Delete Employee" + RESET);
        System.out.println(BLUE_BOLD + "7. Sort Employees by ID" + RESET);
        System.out.println(BLUE_BOLD + "8. Calculate Average Salary" + RESET);
        System.out.println(RED_BOLD + "9. Exit" + RESET);
        System.out.print(GREEN_BOLD + "\nEnter your choice (1-9): " + RESET);
    }
    int getValidChoice() //Method to get correct input in menu
    {
        int choice;
        do 
        {
            choice = Sc.nextInt();
            if (choice < 1 || choice > 9) 
            {
                System.out.println(RED_BOLD + "Invalid choice. Enter a number between 1 and 9." + RESET);
            }
        } while (choice < 1 || choice > 9);
        return choice;
    }
    boolean isValidPhoneNumber(String phoneNumber) //Method to get correct phoneNumber
    {
        if (phoneNumber.length() != 10) 
        {
            return false;
        }
        char firstDigit = phoneNumber.charAt(0);
        return (firstDigit == '9' || firstDigit == '8' || firstDigit == '7'||  firstDigit == '6');
    }
    void addEmployee() //method to add employees
	{
		if (employeeCount >= max_employees) 
		{
			System.out.println(RED_BOLD + "The employee list is full. Unable to add more employees." + RESET);
			return;
		}
		int id = generateEmployeeID();
		Sc.nextLine();
		System.out.print("Enter the employee's name: ");
		String name = Sc.nextLine();
		String phoneNumber;
		while (true) 
		{
			System.out.print("Enter the employee's phone number: ");
			phoneNumber = Sc.nextLine();
			if (isValidPhoneNumber(phoneNumber)) 
			{
				break;
			} 
			else 
			{
				System.out.println(RED_BOLD + "Invalid phone number. Please ensure the number is 10 digits and starts with 6, 7, 8, or 9." + RESET);
			}
		}
		System.out.print("Enter the basic salary: ");
		double salary = Sc.nextDouble();
		System.out.print("Enter the number of paid leaves: ");
		int leaves = Sc.nextInt();
		System.out.print("Enter the bonus: ");
		double bonus = Sc.nextDouble();
		System.out.print("Enter the number of overtime hours: ");
		int overtime = Sc.nextInt();
		System.out.print("Enter the notice period (in days): ");
		int noticePeriod = Sc.nextInt();  
		employees[employeeCount++] = new Employee(id, name, salary, leaves, bonus, overtime, phoneNumber, noticePeriod);
		System.out.println(GREEN_BOLD + "\nEmployee has been successfully added!" + RESET);
	}
    int generateEmployeeID() //Generating employeeId
    {
        return employeeIdCounter++;
    }
    void viewAllEmployees() 
    {
        System.out.println(CYAN_BOLD + "\n=== Employee Details ===" + RESET);
        if (employeeCount == 0) 
        {
            System.out.println(RED_BOLD + "There are no employees to display." + RESET);
            return;
        }
        for (int i = 0; i < employeeCount; i++) 
        {
            employees[i].displayDetails();
        }
    }
    void searchEmployeeById() // Search by ID
    {
        System.out.print("\nEnter the Employee ID to search for: ");
        int id = Sc.nextInt();
        boolean found = false;
        for (int i = 0; i < employeeCount; i++) 
        {
            if (employees[i].employeeId == id) 
            {
                employees[i].displayDetails();
                found = true;
                break;
            }
        }
        if (!found) 
        {
            System.out.println(RED_BOLD + "\nEmployee not found." + RESET);
        }
    }
    void deleteEmployee() 
	{
    System.out.print("\nEnter the Employee ID to delete: ");
    int id = Sc.nextInt();
    boolean found = false;
    for (int i = 0; i < employeeCount; i++) 
	{
        if (employees[i].employeeId == id) 
		{
            found = true;
            if (employees[i].noticePeriod > 0) 
			{
                System.out.println(RED_BOLD + "Cannot delete employee because notice period is pending." + RESET);
                return;
            } 
			else 
			{
                for (int j = i; j < employeeCount - 1; j++) 
				{
                    employees[j] = employees[j + 1];
                }
                employeeCount--;
                System.out.println(GREEN_BOLD + "Employee has been successfully deleted." + RESET);
                break;
            }
        }
    }
    if (!found) 
	{
        System.out.println(RED_BOLD + "\nEmployee not found." + RESET);
    }
}
    void sortEmployeesById() // method to sort by ID
    {
        if (employeeCount == 0) 
        {
            System.out.println(RED_BOLD + "No employees to sort." + RESET);
            return;
        }
        for (int i = 0; i < employeeCount - 1; i++) //Bubble sort
        {
            for (int j = 0; j < employeeCount - i - 1; j++) 
            {
                if (employees[j].employeeId > employees[j + 1].employeeId) 
                {
                    Employee temp = employees[j];
                    employees[j] = employees[j + 1];
                    employees[j + 1] = temp;
                }
            }
        }
        System.out.println(GREEN_BOLD + "\nEmployees have been successfully sorted by ID." + RESET);
        viewAllEmployees();
    }
    void calculateAverageSalary() // Avg. salary calculation
    {
        if (employeeCount == 0) 
        {
            System.out.println(RED_BOLD + "No employees available to calculate the average salary." + RESET);
            return;
        }
        double totalSalary = 0;
        for (int i = 0; i < employeeCount; i++) 
        {
            totalSalary += employees[i].basicSalary;
        }
        double averageSalary = totalSalary / employeeCount;
        System.out.println(GREEN_BOLD + "\nThe average salary of all employees is: Rs." + RESET + averageSalary);
    }
    void editEmployee(String field) // Edit name or salary of employee
    {
        System.out.print("\nEnter the Employee ID to edit: ");
        int id = Sc.nextInt();
        boolean found = false;
        for (int i = 0; i < employeeCount; i++) 
        {
            if (employees[i].employeeId == id) 
            {
                found = true;
                if (field.equals("Name")) 
                {
                    Sc.nextLine();  
                    System.out.print("Enter the new name: ");
                    String newName = Sc.nextLine();
                    employees[i].name = newName;
                    System.out.println(GREEN_BOLD + "Employee's name has been updated successfully!" + RESET);
                } 
                else if (field.equals("Salary")) 
                {
                    System.out.print("Enter the new salary: ");
                    double newSalary = Sc.nextDouble();
                    employees[i].basicSalary = newSalary;
                    System.out.println(GREEN_BOLD + "Employee's salary has been updated successfully!" + RESET);
                }
                break;
            }
        }
        if (!found) 
        {
            System.out.println(RED_BOLD + "\nEmployee not found." + RESET);
        }
    }
}